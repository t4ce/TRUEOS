#!/usr/bin/env bash
set -euo pipefail

repo_root="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
localcoder_dir="${repo_root}/vendor/localcoder"

if [[ ! -d "${localcoder_dir}" ]]; then
  echo "lc: vendored localcoder not found at ${localcoder_dir}" >&2
  exit 1
fi

case "${1-}" in
  -h|--help)
    cat <<'EOF'
lc: launch the vendored host localcoder from this repo

Usage:
  lc
  lc --continue
  lc --resume <session-id>
  lc <prompt...>

Notes:
  - Runs in vendor/localcoder so its local Cargo config/toolchain override applies.
  - All arguments are passed through to localcoder unchanged.
EOF
    exit 0
    ;;
esac

cd "${localcoder_dir}"
exec cargo run -- "$@"

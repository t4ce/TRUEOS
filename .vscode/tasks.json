{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "make dbg",
            "type": "shell",
            "command": "make dbg",
            "isBackground": true,
            "problemMatcher": [
                {
                    "pattern": [
                        {
                            "regexp": "^this_will_never_match_anything$",
                            "file": 1,
                            "location": 2,
                            "message": 3
                        }
                    ],
                    "background": {
                        "activeOnStart": true,
                        "beginsPattern": "Waiting for debugger...",
                        "endsPattern": "^GDB stub ready on 127\\.0\\.0\\.1:1234$"
                    }
                }
            ],
            "presentation": {
                "reveal": "always",
                "panel": "shared"
            }
        }
    ]
}
{
	"version": "2.0.0",
	"tasks": [
		{
			"label": "make dbg",
			"type": "shell",
			"command": "make dbg-vscode",
			"isBackground": true,
			"problemMatcher": [
				{
					"pattern": [
						{
							"regexp": "^this_will_never_match_anything$",
							"file": 1,
							"location": 2,
							"message": 3
						}
					],
					"background": {
						"activeOnStart": true,
						"beginsPattern": "^GDB stub ready on 127\\.0\\.0\\.1:1234$",
						"endsPattern": "^GDB stub ready on 127\\.0\\.0\\.1:1234$"
					}
				}
			],
			"presentation": {
				"reveal": "always",
				"panel": "shared"
			}
		},
		{
			"label": "make iso",
			"type": "shell",
			"command": "make",
			"args": [
				"iso"
			],
			"isBackground": false
		}
	]
}
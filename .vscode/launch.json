{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Debug TRUEOS (QEMU)",
            "type": "cppdbg",
            "request": "launch",
            "program": "${workspaceFolder}/tgt/86_64/debug/TRUEOS",
            "miDebuggerServerAddress": "localhost:1234",
            "cwd": "${workspaceFolder}",
            "MIMode": "gdb",
            "miDebuggerPath": "/usr/bin/gdb",
            "preLaunchTask": "make dbg",
            "setupCommands": [
                {
                    "description": "Enable pretty-printing for gdb",
                    "text": "-enable-pretty-printing",
                    "ignoreFailures": true
                },
                {
                    "text": "set substitute-path /home/t4ce/Repos/TRUEOS ${workspaceFolder}",
                    "description": "Map DWARF paths to the current workspace",
                    "ignoreFailures": true
                },
                {
                    "text": "set mem inaccessible-by-default off",
                    "description": "Allow accessing unmapped memory (fixes breakpoints in boot)",
                    "ignoreFailures": false
                },
                {
                    "text": "set arch i386:x86-64",
                    "description": "Set architecture to x86_64",
                    "ignoreFailures": false
                },
                {
                    "text": "thbreak kmain",
                    "description": "Stop at kernel main",
                    "ignoreFailures": true
                }
            ],
            "logging": {
                "engineLogging": true
            }
        }
    ]
}
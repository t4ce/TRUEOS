#!/usr/bin/env bash
set -euo pipefail

repo_root="$(cd -- "$(dirname -- "$0")/.." && pwd)"
host_target="$(rustc -vV | sed -n 's/^host: //p')"
tmp_dir="$(mktemp -d)"
trap 'rm -rf "$tmp_dir"' EXIT

cp -R "$repo_root/tools/kernel-audit/." "$tmp_dir/"
export CARGO_TARGET_DIR="$tmp_dir/target"
exec cargo run --quiet --target "$host_target" --manifest-path "$tmp_dir/Cargo.toml" -- "$repo_root" "$@"